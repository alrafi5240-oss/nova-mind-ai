# Core
OPENAI_API_KEY=
BACKEND_VERSION=1.0.0

# Models per API version (/v1/chat vs /v2/chat)
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_V2=gpt-4o

# Mobile app update hints (semver strings)
APP_MIN_VERSION=1.0.0
APP_LATEST_VERSION=1.0.0
APP_FORCE_UPDATE=false
APP_UPDATE_MESSAGE=A new version is available with improvements and fixes.
# APP_STORE_URL_ANDROID=https://play.google.com/store/apps/details?id=com.novamind.mobile
# APP_STORE_URL_IOS=https://apps.apple.com/app/id000000000

# Feature flags (remote toggles)
FEATURE_VOICE=true
FEATURE_GPT4_MODEL=false
FEATURE_PREMIUM_UI=true

# Optional JSON override for GET /v1/app/config changelog
# CHANGELOG_JSON=[{"version":"1.0.0","date":"2026-04-01","notes":["First release"]}]
