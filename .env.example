# ============================================================================
# NOVA MIND AI - Production Environment Configuration
# ============================================================================

# REQUIRED: OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk_test_your_key_here

# ============================================================================
# OPTIONAL: LLM Provider Selection
# ============================================================================

# LLM Provider: "openai" or "lite" (default: openai)
# - "openai": Full AI responses via OpenAI API (requires OPENAI_API_KEY)
# - "lite": Simple echo-like responses (no API key required, fallback if unavailable)
LLM_PROVIDER=openai

# ============================================================================
# OPTIONAL: OpenAI Settings
# ============================================================================

# Model selection (default: gpt-4.1-mini)
OPENAI_MODEL=gpt-4.1-mini

# Temperature (randomness): 0=deterministic, 2=maximum randomness (default: 0.7)
OPENAI_TEMPERATURE=0.7

# ============================================================================
# OPTIONAL: Authentication (Disabled by default)
# ============================================================================

# Enable API authentication (default: false)
# REQUIRE_AUTH=false

# API key for authentication (if REQUIRE_AUTH=true)
# API_KEY=your_secret_api_key_here

# ============================================================================
# OPTIONAL: Server Configuration
# ============================================================================

# Server host (default: 0.0.0.0)
HOST=0.0.0.0

# Server port (default: 8000)
PORT=8000

# Environment: development, staging, production (default: development)
ENVIRONMENT=production

# Debug mode (default: false)
DEBUG=false

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# ============================================================================
# OPTIONAL: Application Settings
# ============================================================================

# Backend version
BACKEND_VERSION=1.0.0

# ============================================================================
# DATABASE Configuration (PostgreSQL)
# ============================================================================

# Database URL for PostgreSQL async connection
# Format: postgresql+asyncpg://user:password@host:port/database
# Default: postgresql+asyncpg://user:password@localhost:5432/nova_mind_ai
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nova_mind_ai

# SQL Echo (show SQL queries in logs): true or false (default: false)
SQL_ECHO=false

# ============================================================================
# OPTIONAL: SaaS System Configuration
# ============================================================================

# Admin panel authentication token
ADMIN_TOKEN=your_secret_admin_token_here

# Payment provider API keys (structure only, not integrated yet)
# Stripe
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# bKash
BKASH_API_KEY=your_bkash_api_key

# Nagad
NAGAD_API_KEY=your_nagad_api_key

# Cryptocurrency
CRYPTO_WEBHOOK_SECRET=your_crypto_webhook_secret

# SaaS Plan Limits
FREE_PLAN_LIMIT=10
BASIC_PLAN_LIMIT=500
PRO_PLAN_LIMIT=5000
ELITE_PLAN_LIMIT=-1
